# Create the .gitignore in your project root
cat > ~/Documents/Environments/Francontcube/.gitignore << 'EOF'
# Python
*.pyc
*.pyo
__pycache__/
*.py[cod]

# Django
db.sqlite3
*.sqlite3
staticfiles/
media/

# Environment
.env
*.env
venv/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Migrations (optional - some teams keep these)
# Uncomment below if you want to exclude migrations
# */migrations/*.py
# !*/migrations/__init__.py
EOF